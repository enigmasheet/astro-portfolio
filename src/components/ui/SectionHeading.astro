---
export interface Props {
  label?: string;
  title: string;
  description?: string;
  centered?: boolean;
  as?: 'h1' | 'h2' | 'h3';
}
const { label, title, description, centered, as = 'h2' } = Astro.props;
const Tag = as;
---

<div class={`mb-14 ${centered ? 'text-center' : ''}`} data-reveal>
  {
    label && (
      <span class="inline-block text-xs font-bold tracking-[0.15em] uppercase text-primary mb-4">
        {label}
      </span>
    )
  }
  <Tag class="text-4xl md:text-5xl font-extrabold text-(--color-text) mb-4 leading-tight tracking-tight">
    {title}
  </Tag>
  {
    description && (
      <p class="text-text-secondary max-w-2xl text-lg md:text-xl font-medium leading-relaxed mx-auto">{description}</p>
    )
  }
</div>
