<button class="theme-toggle p-2 rounded-lg text-text-secondary hover:text-primary hover:bg-primary/5 transition-colors cursor-pointer" aria-label="Toggle theme">
  <span class="material-symbols-outlined text-2xl dark-icon">light_mode</span>
  <span class="material-symbols-outlined text-2xl light-icon">dark_mode</span>
</button>

<script>
  (function () {
    var theme = localStorage.getItem('theme') || 'dark';
    document.querySelectorAll('.theme-toggle').forEach(function (btn) {
      var darkIcon = btn.querySelector('.dark-icon') as HTMLElement | null;
      var lightIcon = btn.querySelector('.light-icon') as HTMLElement | null;
      if (theme === 'dark') { if (lightIcon) lightIcon.style.display = 'none'; }
      else { if (darkIcon) darkIcon.style.display = 'none'; }
    });
  })();
</script>

<script>
  import { toggleTheme, getStoredTheme } from '../../styles/theme-toggle';

  var btns = document.querySelectorAll('.theme-toggle');
  btns.forEach(function (btn) {
    function updateIcons(theme: string) {
      var darkIcon = btn.querySelector('.dark-icon') as HTMLElement | null;
      var lightIcon = btn.querySelector('.light-icon') as HTMLElement | null;
      if (!darkIcon || !lightIcon) return;
      if (theme === 'dark') {
        darkIcon.style.display = '';
        lightIcon.style.display = 'none';
      } else {
        darkIcon.style.display = 'none';
        lightIcon.style.display = '';
      }
    }
    updateIcons(getStoredTheme());
    btn.addEventListener('click', function () {
      updateIcons(toggleTheme());
    });
  });
</script>
