---
import ClientRouter from 'astro/components/ClientRouter.astro';
import { SITE_URL, SOCIAL_LINKS, OG_IMAGE_PATH } from '../data/social';
import { SITE } from '../data/site';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
}

const { title, description, ogImage, ogType, canonical } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const fullTitle = title ? `${title} | ${SITE.name}` : `${SITE.fullName} — ${SITE.shortTitle}`;
const metaDesc = description || SITE.shortTitle;
const ogImg = ogImage || `${SITE_URL}${OG_IMAGE_PATH}`;
const canonicalUrl = canonical || SITE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDesc} />
    <meta name="author" content={SITE.fullName} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType || 'website'} />
    <meta property="og:site_name" content={SITE.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDesc} />
    <meta name="twitter:image" content={ogImg} />

    <link rel="icon" type="image/svg+xml" href={base + 'favicon/favicon.svg'} />
    <link rel="icon" type="image/png" href={base + 'favicon/favicon.png'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300..800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block"
    />

    <script>
      (function () {
        const e = localStorage.getItem('theme');
        document.documentElement.setAttribute('data-theme', e || 'dark');
        document.addEventListener('astro:after-swap', function () {
          const t = localStorage.getItem('theme');
          document.documentElement.setAttribute('data-theme', t || 'dark');
        });
      })();
    </script>

    <ClientRouter fallback="animate" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: SITE.fullName,
        jobTitle: SITE.title,
        url: SITE_URL,
        knowsAbout: SITE.knowsAbout,
        sameAs: SOCIAL_LINKS.filter((l) => l.href.startsWith('http')).map((l) => l.href),
      })}
    />

    <slot name="head" />

    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <div id="page-content">
      <slot />
    </div>

    <script>
      import '../scripts/init';
    </script>
  </body>
</html>
