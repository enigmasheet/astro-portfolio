<button
  class="theme-toggle p-3 rounded-lg text-text-secondary hover:text-primary hover:bg-primary/5 transition-colors cursor-pointer"
  aria-label="Toggle theme"
>
  <span class="material-symbols-outlined text-2xl dark-icon theme-icon">light_mode</span>
  <span class="material-symbols-outlined text-2xl light-icon theme-icon">dark_mode</span>
</button>

<script is:inline>
  (function () {
    let theme = 'dark';
    try {
      theme = localStorage.getItem('theme') || 'dark';
    } catch {
      theme = 'dark';
    }
    document.querySelectorAll('.theme-toggle').forEach(function (btn) {
      if (btn.dataset.toggleReady) return;
      const darkIcon = btn.querySelector('.dark-icon');
      const lightIcon = btn.querySelector('.light-icon');
      if (theme === 'dark') {
        if (lightIcon) lightIcon.style.display = 'none';
      } else {
        if (darkIcon) darkIcon.style.display = 'none';
      }
    });
  })();
</script>

<script>
  import { toggleTheme, getStoredTheme } from '../../styles/theme-toggle';

  function initToggles() {
    const btns = document.querySelectorAll<HTMLButtonElement>('.theme-toggle');
    btns.forEach(function (btn) {
      if (btn.dataset.toggleInit) return;
      btn.dataset.toggleInit = 'true';
      function updateIcons(theme: string) {
        const darkIcon = btn.querySelector<HTMLSpanElement>('.dark-icon');
        const lightIcon = btn.querySelector<HTMLSpanElement>('.light-icon');
        if (!darkIcon || !lightIcon) return;
        if (theme === 'dark') {
          darkIcon.style.display = '';
          lightIcon.style.display = 'none';
        } else {
          darkIcon.style.display = 'none';
          lightIcon.style.display = '';
        }
      }
      updateIcons(getStoredTheme());
      btn.addEventListener('click', function () {
        updateIcons(toggleTheme());
        const icon = btn.querySelector<HTMLSpanElement>(
          '.theme-icon:not([style*="display: none"])',
        );
        // Use optional chaining to safely handle possible null
        icon?.classList.add('theme-spin');
        setTimeout(function () {
          icon?.classList.remove('theme-spin');
        }, 300);
      });
    });
  }

  initToggles();
  const w = window as Window & { __themeToggleMO?: MutationObserver };
  if (!w.__themeToggleMO) {
    w.__themeToggleMO = new MutationObserver(initToggles);
    w.__themeToggleMO.observe(document.body, {
      childList: true,
      subtree: true,
    });
  }
</script>
