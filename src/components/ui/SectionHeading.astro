---
export interface Props {
  label?: string;
  title: string;
  description?: string;
  centered?: boolean;
}
const { label, title, description, centered } = Astro.props;
---

<div class={`mb-14 ${centered ? 'text-center' : ''}`} data-reveal>
  {
    label && (
      <span class="inline-block text-xs font-bold tracking-[0.15em] uppercase text-primary mb-4">
        {label}
      </span>
    )
  }
  <h2 class="text-4xl md:text-5xl font-extrabold text-(--color-text) mb-4 leading-tight tracking-tight">
    {title}
  </h2>
  {
    description && (
      <p class="text-text-secondary max-w-2xl text-lg md:text-xl font-medium leading-relaxed mx-auto">{description}</p>
    )
  }
</div>
