---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { SITE_URL } from '../../data/social';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
if (!post) return Astro.redirect(base + '404');

const { Content } = await render(post);
const { title, date, summary, tags } = post.data;
const readingTime = Math.ceil(summary.split(' ').length / 200) || 1;
const postDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const shareUrl = `${SITE_URL}/blog/${post.id}`;
const shareText = `${title} by Abhay Kumar Mandal`;
const breadcrumbItems = [
  { name: 'Home', url: SITE_URL },
  { name: 'Blog', url: `${SITE_URL}/blog` },
  { name: title, url: shareUrl },
];
---

<PageLayout title={title} description={summary} canonical={shareUrl}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbItems.map((item, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: item.name,
      item: item.url,
    })),
  })}></script>

  <div id="progress-bar" class="fixed top-16 left-0 right-0 h-1 bg-(--color-border) z-40">
    <div class="h-full bg-(--color-primary) w-0 transition-all duration-100"></div>
  </div>

  <section class="page-section">
    <div class="max-w-3xl mx-auto px-4">
      <a href={base + 'blog'} class="inline-flex items-center text-sm text-(--color-text-secondary) hover:text-(--color-primary) transition-colors mb-8 no-underline">
        ← Back to Blog
      </a>

      <header class="mb-8" data-reveal>
        <h1 class="text-3xl md:text-4xl font-bold text-(--color-text) mb-4">{title}</h1>
        <div class="flex flex-wrap items-center gap-4 text-sm text-(--color-text-secondary)">
          <span>{postDate}</span>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-(--color-primary)/10 text-(--color-primary) font-medium">
            {readingTime} min read
          </span>
        </div>
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="px-2.5 py-1 text-xs rounded-md bg-(--color-bg) text-(--color-text-secondary)">#{tag}</span>
          ))}
        </div>
      </header>

      <article class="blog-content max-w-none" data-reveal>
        <Content />
      </article>

      <footer class="mt-12 pt-8 border-t border-(--color-border)" data-reveal>
        <p class="text-sm font-medium text-(--color-text) mb-4">Share this post</p>
        <div class="flex items-center gap-3">
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`}
            target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-(--color-border) text-sm text-(--color-text-secondary) hover:text-(--color-primary) hover:border-(--color-primary) transition-colors no-underline"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Twitter
          </a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`}
            target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-(--color-border) text-sm text-(--color-text-secondary) hover:text-(--color-primary) hover:border-(--color-primary) transition-colors no-underline"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <button id="copy-link"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-(--color-border) text-sm text-(--color-text-secondary) hover:text-(--color-primary) hover:border-(--color-primary) transition-colors cursor-pointer"
          >
            <span class="material-symbols-outlined text-lg">link</span>
            <span id="copy-label">Copy link</span>
          </button>
        </div>
      </footer>
    </div>
  </section>

  <script>
    var progressBar = document.querySelector('#progress-bar > div');
    if (progressBar) {
      document.addEventListener('scroll', function () {
        var scrollTop = window.scrollY;
        var docHeight = document.documentElement.scrollHeight - window.innerHeight;
        progressBar.style.width = Math.min((scrollTop / docHeight) * 100, 100) + '%';
      }, { passive: true });
    }

    var copyBtn = document.getElementById('copy-link');
    var copyLabel = document.getElementById('copy-label');
    if (copyBtn && copyLabel) {
      copyBtn.addEventListener('click', async function () {
        try {
          await navigator.clipboard.writeText('{shareUrl}');
          copyLabel.textContent = 'Link copied!';
          setTimeout(function () { copyLabel.textContent = 'Copy link'; }, 2000);
        } catch {}
      });
    }
  </script>
</PageLayout>

<style is:global>
  .blog-content h1, .blog-content h2, .blog-content h3 {
    color: var(--color-text); margin-top: 2rem; margin-bottom: 0.75rem; font-weight: 600;
  }
  .blog-content h1 { font-size: 1.75rem; }
  .blog-content h2 { font-size: 1.5rem; }
  .blog-content h3 { font-size: 1.25rem; }
  .blog-content p {
    color: var(--color-text-secondary); line-height: 1.8; margin-bottom: 1rem;
  }
  .blog-content ul, .blog-content ol {
    color: var(--color-text-secondary); line-height: 1.8; margin: 1rem 0; padding-left: 1.5rem;
  }
  .blog-content li { margin-bottom: 0.25rem; }
  .blog-content code {
    font-family: 'JetBrains Mono', monospace; font-size: 0.875rem;
    background: var(--color-surface); padding: 0.2em 0.4em; border-radius: 4px;
  }
  .blog-content pre code { background: none; padding: 0; }
  .blog-content a { color: var(--color-primary); text-decoration: none; }
  .blog-content a:hover { text-decoration: underline; }
  .blog-content em { font-style: italic; }
  .blog-content strong { font-weight: 600; }
</style>
