---
import { SOCIAL_LINKS } from '../../data/social';
import GitHubIcon from './icons/GitHubIcon.astro';
import LinkedInIcon from './icons/LinkedInIcon.astro';
import EmailIcon from './icons/EmailIcon.astro';
import ResumeIcon from './icons/ResumeIcon.astro';
import RoadmapIcon from './icons/RoadmapIcon.astro';

const iconMap = {
  github: GitHubIcon,
  linkedin: LinkedInIcon,
  email: EmailIcon,
  resume: ResumeIcon,
  roadmap: RoadmapIcon,
};
function getIcon(name: string) {
  return iconMap[name as keyof typeof iconMap];
}
---

<div class="flex items-center gap-3">
  {
    SOCIAL_LINKS.map((link) => {
      const Icon = getIcon(link.icon);
      return (
        <a
          href={link.href}
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="p-3 rounded-lg text-text-secondary hover:text-primary hover:bg-primary/5 hover:scale-110 transition-all"
          aria-label={link.label}
          title={link.label}
        >
          {Icon && <span aria-hidden="true"><Icon /></span>}
        </a>
      );
    })
  }
</div>
