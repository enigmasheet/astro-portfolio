---
import { SOCIAL_LINKS, EMAIL } from '../../data/social';
import { SITE } from '../../data/site';
import GitHubIcon from '../ui/icons/GitHubIcon.astro';
import LinkedInIcon from '../ui/icons/LinkedInIcon.astro';
import EmailIcon from '../ui/icons/EmailIcon.astro';
import ResumeIcon from '../ui/icons/ResumeIcon.astro';
import RoadmapIcon from '../ui/icons/RoadmapIcon.astro';

const iconMap = {
  github: GitHubIcon,
  linkedin: LinkedInIcon,
  email: EmailIcon,
  resume: ResumeIcon,
  roadmap: RoadmapIcon,
};
function getIcon(name: string): (typeof iconMap)[keyof typeof iconMap] | undefined {
  if (name in iconMap) {
    return iconMap[name as keyof typeof iconMap];
  }
  return undefined;
}
const year = new Date().getFullYear();
---

<footer
  class="border-t border-border bg-surface transition-colors duration-300"
  transition:name="footer"
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-4">
        {
          SOCIAL_LINKS.map((link) => {
            const Icon = getIcon(link.icon);
            return (
              <a
                href={link.href}
                target={link.href.startsWith('http') ? '_blank' : undefined}
                rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="text-text-secondary hover:text-primary transition-colors"
                aria-label={link.label}
              >
                {Icon && <Icon />}
              </a>
            );
          })
        }
      </div>
      <div class="text-sm text-text-secondary text-center">
        {`© ${year} ${SITE.fullName}.`}
        <br class="sm:hidden" />
        <a href={`mailto:${EMAIL}`} class="hover:text-primary transition-colors">{EMAIL}</a>
      </div>
    </div>
  </div>
</footer>
