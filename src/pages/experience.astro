---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ExperienceTimeline from '../components/sections/ExperienceTimeline.astro';
import EducationCard from '../components/ui/EducationCard.astro';
import { EXPERIENCES } from '../data/experience';
import { SECTIONS, RESUME } from '../data/site';
---

<PageLayout title="Experience" description={SECTIONS.experience.description}>
  <section class="page-section">
    <div class="max-w-4xl mx-auto px-4">
      <SectionHeading
        as="h1"
        label={SECTIONS.experience.label}
        title={SECTIONS.experience.title}
        description={SECTIONS.experience.description}
        centered
      />
      <ExperienceTimeline items={EXPERIENCES} />
    </div>
  </section>
  <section class="page-section bg-surface transition-colors duration-300">
    <div class="max-w-4xl mx-auto px-4">
      <SectionHeading label="Education" title="Education & Credentials" centered />
      <div class="max-w-xl mx-auto" data-reveal>
        <EducationCard items={RESUME.education} />
      </div>
    </div>
  </section>
</PageLayout>
