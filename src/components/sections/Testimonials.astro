---
import { TESTIMONIALS } from '../../data/testimonials';
---

<div class="grid md:grid-cols-2 gap-6" data-reveal>
  {
    TESTIMONIALS.map((t) => (
      <blockquote class="bg-surface border border-border rounded-xl p-6 relative overflow-hidden before:absolute before:bottom-0 before:left-0 before:right-0 before:h-0.75 before:bg-primary before:opacity-0 before:transition-opacity hover:before:opacity-100">
        <div
          class="text-4xl text-primary/20 absolute top-4 left-4 leading-none select-none"
          aria-hidden="true"
        >
          "
        </div>
        <p class="text-sm text-text-secondary leading-relaxed relative z-10 mb-4 italic">
          "{t.text}"
        </p>
        <footer>
          {t.link ? (
            <a
              href={t.link}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-semibold text-(--color-text) hover:text-primary no-underline transition-colors"
            >
              {t.name}
            </a>
          ) : (
            <p class="text-sm font-semibold text-(--color-text)">{t.name}</p>
          )}
          <p class="text-xs text-text-secondary">{t.role}</p>
          {t.date && t.relationship && (
            <p class="text-xs text-text-secondary/60 mt-1">{t.date} &middot; {t.relationship}</p>
          )}
        </footer>
      </blockquote>
    ))
  }
</div>
