---
import { STATS } from '../../data/site';
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-6" data-reveal>
  {
    STATS.map((stat) => (
      <div class="stat-tile text-center p-6 rounded-xl bg-(--color-surface) border border-(--color-border) transition-all hover:shadow-md duration-300 relative overflow-hidden before:absolute before:bottom-0 before:left-0 before:right-0 before:h-[3px] before:bg-(--color-primary) before:opacity-0 before:transition-opacity hover:before:opacity-100" data-theme-aware>
        <div class="text-3xl md:text-4xl font-bold text-(--color-primary) mb-2">
          <span
            class="counter"
            data-target={stat.target}
            data-suffix={stat.suffix}
          >0{stat.suffix}</span>
        </div>
        <div class="text-sm text-(--color-text-secondary) font-medium">
          {stat.label}
        </div>
      </div>
    ))
  }
</div>
