---
import type { Experience } from '../../types';
export interface Props {
  items: Experience[];
}
const { items } = Astro.props;

function formatDate(d: string): string {
  const date = new Date(d);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
}

function isPresent(endDate: string | null): boolean {
  return !endDate;
}
---

<div class="relative" data-reveal>
  <div class="absolute left-[19px] top-2 bottom-2 w-0.5 bg-(--color-border)"></div>
  <div class="space-y-8">
    {
      items.map((item) => (
        <div class="relative pl-12">
          <div class="absolute left-2.5 top-1.5 w-[9px] h-[9px] rounded-full bg-(--color-primary) ring-4 ring-(--color-bg)"></div>
          <div class="exp-card bg-(--color-surface) border border-(--color-border) rounded-xl p-6 transition-all hover:shadow-md duration-300 relative overflow-hidden before:absolute before:bottom-0 before:left-0 before:right-0 before:h-[3px] before:bg-(--color-primary) before:opacity-0 before:transition-opacity hover:before:opacity-100" data-theme-aware>
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-3">
              <div>
                <h3 class="text-lg font-semibold text-(--color-text)">{item.title}</h3>
                <p class="text-sm font-medium text-(--color-primary)">{item.company}</p>
              </div>
              <span class="text-xs text-(--color-text-secondary) whitespace-nowrap px-3 py-1 rounded-full bg-(--color-bg)">
                {formatDate(item.date)} – {isPresent(item.endDate) ? 'Present' : formatDate(item.endDate!)}
              </span>
            </div>
            <p class="text-sm text-(--color-text-secondary) leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))
    }
  </div>
</div>
