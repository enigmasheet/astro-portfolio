---
import { NAV_LINKS } from '../../data/navigation';
import ThemeToggle from './ThemeToggle.astro';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/85 backdrop-blur-md border-b border-border transition-colors duration-300" data-theme-aware>
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href={base} class="text-xl font-bold tracking-tight no-underline text-(--color-text)">
      &lt;Abhay /&gt;
    </a>
    <div class="hidden md:flex items-center gap-1">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="nav-link px-3 py-2 rounded-lg text-sm font-medium text-text-secondary hover:text-primary hover:bg-primary/5 transition-colors no-underline"
          >
            {link.label}
          </a>
        ))
      }
      <ThemeToggle />
    </div>
    <div class="flex md:hidden items-center gap-2">
      <ThemeToggle />
      <button id="nav-toggle" class="p-2 rounded-lg text-text-secondary hover:text-primary transition-colors cursor-pointer" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-drawer">
        <span class="material-symbols-outlined text-2xl">menu</span>
      </button>
    </div>
  </div>
</nav>

<div id="drawer-backdrop" class="fixed inset-0 z-30 bg-black/30 md:hidden invisible opacity-0 transition-[opacity,visibility] duration-300 ease-in-out"></div>
<div id="mobile-drawer" class="fixed top-16 left-0 right-0 z-40 bg-surface border-b border-border shadow-lg md:hidden invisible opacity-0 -translate-y-2 transition-[opacity,transform,visibility] duration-300 ease-in-out" data-theme-aware>
  <div class="px-4 py-2 flex flex-col gap-1">
    {
      NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class="nav-link px-3 py-3 rounded-lg text-sm font-medium text-text-secondary hover:text-primary hover:bg-primary/5 transition-colors no-underline"
        >
          {link.label}
        </a>
      ))
    }
  </div>
</div>

<script>
  import '../../scripts/navbar';
</script>
