---
import { HERO, SITE } from '../../data/site';
import SocialLinks from '../ui/SocialLinks.astro';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const phrases =
  '.NET Backend Developer|Full-Stack .NET Developer|Problem Solver|Continuous Learner';
const firstPhrase = '.NET Backend Developer';
---

<section class="relative min-h-[calc(100vh-64px)] flex items-center overflow-hidden">
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div
      class="absolute -top-40 -right-40 w-96 h-96 rounded-full blur-[100px]"
      style="background: var(--nord8); opacity: 0.08; animation: heroOrbA 20s ease-in-out infinite"
    >
    </div>
    <div
      class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full blur-[100px]"
      style="background: var(--nord7); opacity: 0.08; animation: heroOrbB 25s ease-in-out infinite"
    >
    </div>
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: radial-gradient(circle, currentColor 1px, transparent 1px); background-size: 40px 40px;"
    >
    </div>
    <div
      class="absolute top-1/4 left-[15%] text-6xl font-bold opacity-[0.015] select-none pointer-events-none"
      style="font-family: var(--font-mono);"
      aria-hidden="true"
    >{`{`}</div>
    <div
      class="absolute bottom-1/4 right-[20%] text-6xl font-bold opacity-[0.015] select-none pointer-events-none"
      style="font-family: var(--font-mono);"
      aria-hidden="true"
    >{`}`}</div>
    <div
      class="absolute top-1/3 right-[10%] text-sm font-bold opacity-[0.02] select-none pointer-events-none rotate-12"
      style="font-family: var(--font-mono);"
      aria-hidden="true"
    >{`// build-systems`}</div>
    <div
      class="absolute bottom-1/3 left-[8%] text-lg font-bold opacity-[0.015] select-none pointer-events-none -rotate-6"
      style="font-family: var(--font-mono);"
      aria-hidden="true"
    >{`=>`}</div>

    <span
      class="absolute top-[25%] left-[60%] text-xs font-medium px-2.5 py-1 rounded-full opacity-[0.06] select-none pointer-events-none"
      style="background: var(--nord8); animation: tagFloat 18s ease-in-out infinite;"
      aria-hidden="true"
    >C#</span>
    <span
      class="absolute top-[55%] left-[70%] text-xs font-medium px-2.5 py-1 rounded-full opacity-[0.06] select-none pointer-events-none"
      style="background: var(--nord10); animation: tagFloat 22s ease-in-out infinite reverse;"
      aria-hidden="true"
    >.NET</span>
    <span
      class="absolute top-[15%] left-[75%] text-xs font-medium px-2.5 py-1 rounded-full opacity-[0.05] select-none pointer-events-none"
      style="background: var(--nord7); animation: tagFloat 15s ease-in-out infinite; animation-delay: -5s;"
      aria-hidden="true"
    >Azure</span>
    <span
      class="absolute top-[70%] left-[55%] text-xs font-medium px-2.5 py-1 rounded-full opacity-[0.05] select-none pointer-events-none"
      style="background: var(--nord9); animation: tagFloat 20s ease-in-out infinite; animation-delay: -10s;"
      aria-hidden="true"
    >SQL</span>
  </div>
  <div class="max-w-6xl mx-auto px-4 py-24 relative z-10 w-full">
    <div class="max-w-3xl">
      <div
        class="flex items-center gap-3 mb-4"
        style="animation: heroFadeIn 0.6s ease 0.1s forwards; opacity:0;"
      >
        <div class="w-8 h-px bg-primary/60"></div>
        <p class="text-sm font-semibold tracking-widest uppercase text-primary">
          {HERO.greeting}
        </p>
      </div>
      <h1
        class="text-4xl md:text-6xl lg:text-7xl font-bold mb-4 leading-tight bg-gradient-to-r from-[var(--nord10)] to-[var(--nord8)] bg-clip-text text-transparent"
        style="animation: heroFadeIn 0.6s ease 0.2s forwards; opacity:0; text-shadow: 0 0 40px color-mix(in srgb, var(--nord8) 20%, transparent), 0 0 80px color-mix(in srgb, var(--nord8) 10%, transparent);"
      >
        {SITE.fullName}
        <span class="block text-2xl md:text-3xl text-text-secondary font-normal mt-2" style="text-shadow: none;">{SITE.jobTitle}</span>
      </h1>
      <div
        class="text-xl md:text-2xl text-text-secondary mb-6 min-h-8"
        style="animation: heroFadeIn 0.6s ease 0.3s forwards; opacity:0;"
      >
        <span
          data-typing
          data-phrases={phrases}
          data-speed="80"
          data-delete-speed="40"
          data-pause="2500"
          data-delay="1200">{firstPhrase}</span
        >
      </div>
      <p
        class="text-lg text-text-secondary max-w-xl leading-relaxed mb-6"
        style="animation: heroFadeIn 0.6s ease 0.4s forwards; opacity:0;"
      >
        {HERO.description}
      </p>
      <div
        class="flex items-center gap-2 mb-8"
        style="animation: heroFadeIn 0.6s ease 0.45s forwards; opacity:0;"
      >
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--success)] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[var(--success)]"></span>
        </span>
        <span class="text-xs font-medium text-text-secondary">Open for opportunities</span>
      </div>
      <div
        class="flex flex-wrap gap-4"
        style="animation: heroFadeIn 0.6s ease 0.5s forwards; opacity:0;"
      >
        <a
          href={base + 'projects/'}
          class="inline-flex items-center px-6 py-3 rounded-lg bg-primary text-white font-medium hover:bg-primary-dark transition-all no-underline"
          style="box-shadow: 0 0 20px color-mix(in srgb, var(--accent) 30%, transparent);"
        >
          {HERO.primaryCta}
        </a>
        <a
          href={base + 'contact/'}
          class="inline-flex items-center px-6 py-3 rounded-lg border-2 border-primary text-primary font-medium hover:bg-primary/5 transition-colors no-underline"
        >
          {HERO.secondaryCta}
        </a>
      </div>
      <div class="mt-12" style="animation: heroFadeIn 0.6s ease 0.6s forwards; opacity:0;">
        <SocialLinks />
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1"
    style="animation: heroFadeIn 0.6s ease 1s forwards; opacity:0;"
    aria-hidden="true"
  >
    <span class="text-xs text-text-muted tracking-widest uppercase font-medium">Scroll</span>
    <svg class="w-4 h-4 text-text-muted animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </div>
</section>
