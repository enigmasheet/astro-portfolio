---
import type { Experience } from '../../types';
export interface Props {
  items: Experience[];
}
const { items } = Astro.props;

function formatDate(d: string): string {
  const date = new Date(d);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
}
---

<div class="space-y-4" data-reveal>
  {
    items.map((item) => (
      <div class="bg-surface border border-border rounded-lg p-4">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-1">
          <div>
            <h3 class="text-sm font-semibold text-(--color-text)">{item.title}</h3>
            <p class="text-xs font-medium text-primary">{item.company}</p>
          </div>
          <span class="text-xs text-text-secondary whitespace-nowrap">
            {formatDate(item.date)} – {item.endDate ? formatDate(item.endDate) : 'Present'}
          </span>
        </div>
        <p class="text-xs text-text-secondary leading-relaxed mt-1">{item.description}</p>
      </div>
    ))
  }
</div>
