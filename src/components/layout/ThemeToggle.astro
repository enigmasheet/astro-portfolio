<button class="theme-toggle p-2 rounded-lg text-(--color-text-secondary) hover:text-(--color-primary) hover:bg-(--color-primary)/5 transition-colors cursor-pointer" aria-label="Toggle theme">
  <span class="material-symbols-outlined text-2xl block dark-icon">light_mode</span>
  <span class="material-symbols-outlined text-2xl hidden light-icon">dark_mode</span>
</button>

<script>
  import { toggleTheme, getStoredTheme } from '../../styles/theme-toggle';

  var btns = document.querySelectorAll('.theme-toggle');
  var initialTheme = getStoredTheme();
  btns.forEach(function (btn) {
    function updateIcons(theme) {
      var darkIcon = btn.querySelector('.dark-icon');
      var lightIcon = btn.querySelector('.light-icon');
      if (theme === 'dark') {
        darkIcon?.classList.remove('hidden');
        lightIcon?.classList.add('hidden');
      } else {
        darkIcon?.classList.add('hidden');
        lightIcon?.classList.remove('hidden');
      }
    }
    updateIcons(initialTheme);
    btn.addEventListener('click', function () {
      updateIcons(toggleTheme());
    });
  });
</script>
