---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import Skills from '../components/sections/Skills.astro';
import Timeline from '../components/sections/Timeline.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';
import BlogCard from '../components/ui/BlogCard.astro';
import { SECTIONS, ABOUT, SITE } from '../data/site';
import { EXPERIENCES } from '../data/experience';
import { PROJECTS } from '../data/projects';
import { getCollection } from 'astro:content';
import { CERTIFICATIONS } from '../data/certifications';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const blogPosts = (await getCollection('blog')).map((p) => ({
  slug: p.id,
  title: p.data.title,
  date: p.data.date.toISOString().split('T')[0],
  summary: p.data.summary,
  tags: p.data.tags,
}));
---

<PageLayout title={SITE.fullName} description={SITE.shortTitle}>
  <Hero />

  <section id="overview" class="page-section">
    <div class="max-w-6xl mx-auto px-4">
      <SectionHeading
        label={SECTIONS.overview.label}
        title={SECTIONS.overview.title}
        description={SECTIONS.overview.description}
        centered
      />
      <Stats />
    </div>
  </section>

  <section id="about" class="page-section bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-4">
      <SectionHeading
        label={SECTIONS.about.label}
        title={SECTIONS.about.title}
        description={SECTIONS.about.description}
        centered
      />

      <div class="grid lg:grid-cols-[1fr_400px] gap-12 items-start">
        <div class="space-y-4" data-reveal>
          {ABOUT.paragraphs.map((p) => <p class="text-text-secondary leading-relaxed">{p}</p>)}
        </div>

        <div class="space-y-8">
          <div data-reveal>
            <h3 class="text-base font-semibold text-(--color-text) mb-4">
              {ABOUT.blockTitles.skills}
            </h3>
            <Skills />
          </div>

          {
            CERTIFICATIONS.length > 0 && (
              <div data-reveal>
                <h3 class="text-base font-semibold text-(--color-text) mb-4">
                  {ABOUT.blockTitles.certifications}
                </h3>
                <div class="space-y-3">
                  {CERTIFICATIONS.map((cert) => (
                    <a
                      href={cert.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-3 p-4 rounded-xl bg-bg border border-border hover:border-primary transition-colors no-underline"
                    >
                      {cert.imageUrl ? (
                        <img
                          src={cert.imageUrl}
                          alt={cert.title}
                          class="w-10 h-10 rounded object-cover"
                          loading="lazy"
                        />
                      ) : (
                        <span class="material-symbols-outlined text-primary">verified</span>
                      )}
                      <div>
                        <p class="text-sm font-medium text-(--color-text)">{cert.title}</p>
                        <p class="text-xs text-text-secondary">{cert.issuer}</p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )
          }

          <div data-reveal>
            <h3 class="text-base font-semibold text-(--color-text) mb-4">
              {ABOUT.blockTitles.achievements}
            </h3>
            <div class="space-y-3">
              {
                ABOUT.achievements.map((a) => (
                  <div class="flex gap-3 p-4 rounded-xl bg-bg border border-border">
                    <span class="text-xs font-bold text-primary whitespace-nowrap mt-0.5">
                      {a.year}
                    </span>
                    <div>
                      <p class="text-sm font-medium text-(--color-text)">{a.title}</p>
                      <p class="text-xs text-text-secondary">{a.description}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <div class="mt-16 text-center" data-reveal>
        <blockquote
          class="text-xl md:text-2xl font-medium text-(--color-text) italic max-w-2xl mx-auto"
          id="rotating-quote"
          data-quotes={JSON.stringify(ABOUT.quotes)}
        >
          &ldquo;{ABOUT.quotes[0]}&rdquo;
        </blockquote>
      </div>
    </div>
  </section>

  <section id="experience" class="page-section">
    <div class="max-w-4xl mx-auto px-4">
      <SectionHeading
        label={SECTIONS.experience.label}
        title={SECTIONS.experience.title}
        description={SECTIONS.experience.description}
        centered
      />
      <Timeline items={EXPERIENCES} />
    </div>
  </section>

  <section id="testimonials" class="page-section bg-surface transition-colors duration-300">
    <div class="max-w-4xl mx-auto px-4">
      <SectionHeading
        label={SECTIONS.testimonials.label}
        title={SECTIONS.testimonials.title}
        description={SECTIONS.testimonials.description}
        centered
      />
      <Testimonials />
    </div>
  </section>

  <section id="projects" class="page-section">
    <div class="max-w-6xl mx-auto px-4">
      <SectionHeading
        label={SECTIONS.projects.label}
        title={SECTIONS.projects.title}
        description={SECTIONS.projects.description}
        centered
      />
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {PROJECTS.slice(0, 3).map((p) => <ProjectCard project={p} />)}
      </div>
      <div class="text-center mt-8" data-reveal>
        <a
          href={base + 'projects/'}
          class="inline-flex items-center px-6 py-3 rounded-lg border-2 border-primary text-primary font-medium hover:bg-primary/5 transition-colors no-underline"
        >
          View All Projects →
        </a>
      </div>
    </div>
  </section>

  <section id="blog" class="page-section bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-4">
      <SectionHeading
        label={SECTIONS.blog.label}
        title={SECTIONS.blog.title}
        description={SECTIONS.blog.description}
        centered
      />
      <div class="grid md:grid-cols-2 gap-6">
        {blogPosts.map((post) => <BlogCard post={post} />)}
      </div>
      <div class="text-center mt-8" data-reveal>
        <a
          href={base + 'blog/'}
          class="inline-flex items-center px-6 py-3 rounded-lg border-2 border-primary text-primary font-medium hover:bg-primary/5 transition-colors no-underline"
        >
          View All Posts →
        </a>
      </div>
    </div>
  </section>

  <section id="contact" class="page-section">
    <div class="max-w-6xl mx-auto px-4">
      <SectionHeading
        label={SECTIONS.contact.label}
        title={SECTIONS.contact.title}
        description={SECTIONS.contact.description}
        centered
      />
      <div class="max-w-xl mx-auto" data-reveal>
        <form action="https://formspree.io/f/xvgkrkwk" method="POST" class="space-y-4">
          <div class="sr-only" aria-hidden="true">
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>
          <input type="hidden" name="_subject" value="Portfolio Contact" />
          <div>
            <label for="name" class="block text-sm font-medium text-(--color-text) mb-1">Name</label
            >
            <input
              type="text"
              id="name"
              name="name"
              required
              maxlength="100"
              class="w-full px-4 py-2.5 rounded-lg border border-border bg-surface text-(--color-text) focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-(--color-text) mb-1"
              >Email</label
            >
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2.5 rounded-lg border border-border bg-surface text-(--color-text) focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-(--color-text) mb-1"
              >Message</label
            >
            <textarea
              id="message"
              name="message"
              required
              maxlength="5000"
              rows="5"
              class="w-full px-4 py-2.5 rounded-lg border border-border bg-surface text-(--color-text) focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all resize-y"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full px-6 py-3 rounded-lg bg-primary text-white font-medium hover:bg-primary-dark transition-colors cursor-pointer"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</PageLayout>
